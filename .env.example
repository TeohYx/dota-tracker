# Default tracked Dota 2 account ID for guests (Steam32). Public.
DEFAULT_ACCOUNT_ID=403281874

# HMAC secret for the auth cookie. Use ≥32 hex chars in production.
APP_SECRET=long-random-string-min-32-chars

# Local dev: leave commented to use file-based SQLite at ./data/tracker.db
# Production (Vercel + Turso): set both.
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=

# Optional: OpenDota API key for higher rate limits (free at opendota.com).
# Recommended in prod since cron polling will hit OpenDota every few minutes.
# OPENDOTA_API_KEY=

# --- Telegram notifications (only if you want notifications enabled) ---
# Bot token from @BotFather.
# TELEGRAM_BOT_TOKEN=
# Bot username, no @ and no t.me/. Used to build t.me/<username>?start=<code>.
# TELEGRAM_BOT_USERNAME=
# Random secret. Sent as X-Telegram-Bot-Api-Secret-Token; we reject any
# webhook delivery without it.
# TELEGRAM_WEBHOOK_SECRET=

# --- Cron secret (required for /api/cron/* endpoints) ---
# Random string. cron-job.org should send it as:
#   Authorization: Bearer <secret>
# (or X-Cron-Secret: <secret>). Anything else is rejected.
# CRON_SECRET=
