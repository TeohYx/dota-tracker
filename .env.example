# Default tracked Dota 2 account ID for guests (Steam32). Public.
DEFAULT_ACCOUNT_ID=403281874

# HMAC secret for the auth cookie. Use ≥32 hex chars in production.
APP_SECRET=long-random-string-min-32-chars

# Local dev: leave commented to use file-based SQLite at ./data/tracker.db
# Production (Vercel + Turso): set both.
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=

# Optional: OpenDota API key for higher rate limits (free at opendota.com)
# OPENDOTA_API_KEY=

# --- Telegram notifications (optional, only needed if you want notifications) ---
# Bot token from @BotFather
# TELEGRAM_BOT_TOKEN=
# Bot username (without @). Used to build the t.me/<username>?start=<code> link.
# TELEGRAM_BOT_USERNAME=
# Random secret. Sent as X-Telegram-Bot-Api-Secret-Token; we reject webhook
# requests without it.
# TELEGRAM_WEBHOOK_SECRET=

# --- Cron secret (required for /api/cron/* endpoints) ---
# Random string. cron-job.org sends it as: Authorization: Bearer <secret>
# (or X-Cron-Secret: <secret>). Anything that doesn't match is rejected.
# CRON_SECRET=
